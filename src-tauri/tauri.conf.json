{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ModuDesk",
  "version": "0.1.0",
  "identifier": "com.user.modudesk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/favicon_32x32.png",
      "icons/favicon_128x128.png",
      "icons/favicon_32x32.ico",
      "icons/favicon_128x128.ico"
    ],
    "resources": [
      "data/**/*"
    ]
  }
}
