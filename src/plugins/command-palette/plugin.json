{
  "id": "builtin.command-palette",
  "name": "Command Palette",
  "version": "1.0.0",
  "description": "Built-in command palette plugin that lists and runs all commands",
  "activationEvents": [
    "onStartup",
    "onCommand:commandPalette.open",
    "onCommand:*",
    "onView:commandPalette.main",
    "onView:*"
  ],
  "views": [
    {
      "id": "commandPalette.main",
      "title": "Command Palette",
      "component_path": "builtin.command-palette/view/CommandPaletteView",
      "props": {}
    }
  ],
  "commands": [
    {
      "id": "commandPalette.open",
      "description": "Open command palette view"
    },
    {
      "id": "commandPalette.openWelcomeViaCommand",
      "description": "Open welcome via cross-plugin command execution"
    },
    {
      "id": "commandPalette.explainHooks",
      "description": "Print activation hook explanations"
    },
    {
      "id": "commandPalette.toggleVerbose",
      "description": "Toggle command-palette verbose setting"
    }
  ]
}
