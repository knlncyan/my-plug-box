{
  "id": "builtin.welcome",
  "name": "Welcome",
  "version": "1.0.0",
  "description": "Welcome page shown on startup",
  "main": "./index.ts",
  "activationEvents": ["onStartup"],
  "contributes": {
    "commands": [
      {
        "id": "welcome.open",
        "title": "Open Welcome Page",
        "category": "Welcome"
      }
    ],
    "views": [
      {
        "id": "welcome.mainView",
        "name": "Welcome",
        "location": "main"
      }
    ],
    "menus": [
      {
        "context": "menubar",
        "command": "welcome.open",
        "group": "help"
      }
    ]
  }
}
