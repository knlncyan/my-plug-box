{
  "name": "@modudesk/plugin-devtool",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "modudesk-plugin": "./bin/modudesk-plugin.mjs"
  },
  "scripts": {
    "update:sdk": "node ./scripts/update-sdk-types.mjs",
    "init:react": "node ./bin/modudesk-plugin.mjs init ./my_plugin --framework=react --plugin-id=my.plugin",
    "build:executables": "node ./scripts/build-executables.mjs",
    "build:executables:all": "node ./scripts/build-executables.mjs --targets=windows,linux,macos"
  },
  "devDependencies": {
    "esbuild": "^0.25.4",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "bin/modudesk-sdk-types.json",
      "bin/modudesk-plugin.mjs"
    ]
  }
}
