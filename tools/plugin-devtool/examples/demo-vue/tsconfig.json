{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "lib": ["ES2020", "DOM"],
    "baseUrl": ".",
    "paths": {
      "@plug-box/plugin-sdk": ["./sdk/index.ts"]
    }
  },
  "include": ["src", "sdk"]
}